; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but it can also be manually edited with care.

[application]

config/name="Echoes of Choice"
config/description="A visual RPG built on the Echoes of Choice universe."
run/main_scene=""
config/features=PackedStringArray("4.6", "GL Compatibility")

[autoload]

InputConfig="*res://scripts/autoload/input_config.gd"
SceneManager="*res://scripts/autoload/scene_manager.gd"
GameState="*res://scripts/autoload/game_state.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/mode=3
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[gui]

theme/custom="res://resources/gui/game_theme.tres"

[rendering]

textures/canvas_textures/default_texture_filter=0
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
environment/defaults/default_clear_color=Color(0.05, 0.05, 0.08, 1)
